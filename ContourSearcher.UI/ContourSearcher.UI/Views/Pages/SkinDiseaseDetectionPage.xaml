<Page x:Class="ContourSearcher.UI.Views.Pages.SkinDiseaseDetectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ContourSearcher.UI.Views.Pages"
      xmlns:vm="clr-namespace:ContourSearcher.UI.ViewModels.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SkinDiseaseDetectionPage"
      d:DataContext="{d:DesignInstance vm:SkinDiseaseDetectionPageViewModel, IsDesignTimeCreatable=True}"
      Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource MainBorderStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Visible">
                <StackPanel Orientation="Vertical" Height="1500">

                    <Frame Content="{Binding SkinDiseasePage}"
                           NavigationUIVisibility="Hidden"/>

                    <Rectangle Style="{StaticResource BorderRectStyle}"/>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
