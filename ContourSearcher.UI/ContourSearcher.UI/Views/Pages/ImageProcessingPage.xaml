<Page x:Class="ContourSearcher.UI.Views.Pages.ImageProcessingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ContourSearcher.UI.Views.Pages"
      xmlns:vm="clr-namespace:ContourSearcher.UI.ViewModels.Pages"
      xmlns:custControls="clr-namespace:UserControls;assembly=UserControls"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="800"
      d:DataContext="{d:DesignInstance vm:ImageProcessingViewModel, IsDesignTimeCreatable=True}"
      Background="White" x:Name="ImgProcGrid">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource MainBorderStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Visible">
                <StackPanel Orientation="Vertical" Height="1500">

                    <Frame Content="{Binding HistogramPage}" 
                           NavigationUIVisibility="Hidden"/>

                    <Frame Content="{Binding EqualizerPage}"
                           NavigationUIVisibility="Hidden"/>

                    <Frame Content="{Binding FilteringPage}"
                           NavigationUIVisibility="Hidden"/>
                    
                    <Rectangle Style="{StaticResource BorderRectStyle}"/>

                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</Page>
