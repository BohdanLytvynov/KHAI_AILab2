<Page x:Class="ContourSearcher.UI.Views.Pages.ImageProcessingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ContourSearcher.UI.Views.Pages"
      xmlns:vm="clr-namespace:ContourSearcher.UI.ViewModels.Pages"
      xmlns:fa5="http://schemas.fontawesome.com/icons/"
      xmlns:custControls="clr-namespace:UserControls;assembly=UserControls"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="800"
      d:DataContext="{d:DesignInstance vm:ImageProcessingViewModel, IsDesignTimeCreatable=True}"
      Background="White" x:Name="ImgProcGrid">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource MainBorderStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Visible">
                <StackPanel Orientation="Vertical" Height="700">
                    
                    <StackPanel Orientation="Horizontal" Style="{StaticResource HorizontalStack}">
                        <Label Content="Choose source image for processing:" Style="{StaticResource InputTxtBoxLabel}"/>
                        <ComboBox ItemsSource="{Binding ActiveWindows, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedItem="{Binding ImgSourceForSmooth, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                        <Button Margin="20,0,0,0" Command="{Binding OnRefreshActiveWindowsPressed}"
                                ToolTip="Press to update the list of Images that are loaded.">
                            <fa5:SvgAwesome Icon="Solid_RedoAlt" 
                                Height="20"
                                Width="30"
                                Foreground="#FF6B6B6B"/>
                        </Button>
                    </StackPanel>

                    <Rectangle Style="{StaticResource BorderRectStyle}"/>
                    <TextBlock Text="Image Smoothing: (Comming soon)" Style="{StaticResource DescLabel}"/>
                    <Rectangle Style="{StaticResource BorderRectStyle}"/>

                    <!--<StackPanel Orientation="Horizontal" Style="{StaticResource HorizontalStack}">
                        <Label Style="{StaticResource InputTxtBoxLabel}" Content="Choose smoothing:"/>
                        <ComboBox ItemsSource="{Binding Source={StaticResource SmoothingType}}"
                                      SelectedItem="{Binding SmoothingType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      />
                    </StackPanel>

                    <CheckBox Margin="10,0,0,0"
                        Content="Use dynamic update mode"
                        VerticalContentAlignment="Center"
                        FontSize="20"
                        IsChecked="{Binding UseDynamicMode,
                        UpdateSourceTrigger=PropertyChanged,
                        Mode=TwoWay}"/>-->

                    <!--<custControls:Slider LabelText="Size1:" Deliminator=","
                                         LabelStyle="{StaticResource InputTxtBoxLabel}"
                                         Margin="20" Value="{Binding Size1, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                         SliderStyle="{StaticResource SliderIntStyle}"
                                         IntegerPartTextBoxStyle="{StaticResource TxtBoxInputStyle}"
                                         FloatPartTextBoxStyleProperty="{StaticResource TxtBoxInputStyle}"/>

                    <custControls:Slider LabelText="Size2:" Deliminator=","
                        LabelStyle="{StaticResource InputTxtBoxLabel}"
                        Margin="20" Value="{Binding Size2, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                        SliderStyle="{StaticResource SliderIntStyle}"
                        IntegerPartTextBoxStyle="{StaticResource TxtBoxInputStyle}"
                        FloatPartTextBoxStyleProperty="{StaticResource TxtBoxInputStyle}"/>

                    <custControls:Slider LabelText="Sigma1:" Deliminator=","
                        LabelStyle="{StaticResource InputTxtBoxLabel}"
                        Margin="20" Value="{Binding Sigma1, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                        SliderStyle="{StaticResource SliderFloatStyle}"
                        IntegerPartTextBoxStyle="{StaticResource TxtBoxInputStyle}"
                        FloatPartTextBoxStyleProperty="{StaticResource TxtBoxInputStyle}"/>

                    <custControls:Slider LabelText="Sigma2:" Deliminator=","
                        LabelStyle="{StaticResource InputTxtBoxLabel}"
                        Margin="20" Value="{Binding Sigma2, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                        SliderStyle="{StaticResource SliderFloatStyle}"
                        IntegerPartTextBoxStyle="{StaticResource TxtBoxInputStyle}"
                        FloatPartTextBoxStyleProperty="{StaticResource TxtBoxInputStyle}"/>-->

                    <!--<Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="155"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="1" 
        Content="Smooth Image"
        Command="{Binding OnSmoothImageButtonPressed}"
                                Style="{StaticResource SimpleButton}"/>
                    </Grid>-->

                    <Rectangle Style="{StaticResource BorderRectStyle}"/>
                    <TextBlock Text="Histograms:" Style="{StaticResource DescLabel}"/>
                    <Rectangle Style="{StaticResource BorderRectStyle}"/>

                    
                    
                    <Rectangle Style="{StaticResource BorderRectStyle}"/>
                    
                    
                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</Page>
