<Page x:Class="ContourSearcher.UI.Views.Pages.Modules.EqualizerModule"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ContourSearcher.UI.Views.Pages.Modules"
      xmlns:fa5="http://schemas.fontawesome.com/icons/"
      xmlns:vm="clr-namespace:ContourSearcher.UI.ViewModels.Pages.Modules"
      xmlns:custControls="clr-namespace:UserControls;assembly=UserControls"
      mc:Ignorable="d" 
      d:DesignHeight="580" d:DesignWidth="800"
      Title="EqualizerModule"
      d:DataContext="{d:DesignInstance vm:EqualizerModuleViewModel, IsDesignTimeCreatable=True}"
      >
    <Page.Resources>
        <Style x:Key="ClipLimit" TargetType="Slider" BasedOn="{StaticResource SliderBaseStyle}">
            <Style.Setters>
                <Setter Property="TickFrequency" Value="0.1"/>
            </Style.Setters>
        </Style>

        <Style x:Key="TileWidth" TargetType="Slider" BasedOn="{StaticResource SliderBaseStyle}">
            <Style.Setters>
                <Setter Property="Minimum" Value="8"/>
                <Setter Property="Maximum" Value="100"/>
                <Setter Property="TickFrequency" Value="1"/>
            </Style.Setters>
        </Style>
    </Page.Resources>
    <Grid>
        <StackPanel Orientation="Vertical">
            <Rectangle Style="{StaticResource BorderRectStyle}"/>
            <TextBlock Text="{Binding ModuleName}" Style="{StaticResource DescLabel}"/>
            <Rectangle Style="{StaticResource BorderRectStyle}"/>
            
            <StackPanel Style="{StaticResource HorizontalStack}">
                <Label Content="Choose source image for processing:" Style="{StaticResource InputTxtBoxLabel}"/>
                <ComboBox ItemsSource="{Binding ActiveWindows, UpdateSourceTrigger=PropertyChanged}"
  SelectedItem="{Binding ImgNameForProcessing, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                <Button Margin="20,0,0,0" Command="{Binding OnRefreshActiveWindowsPressed}"
ToolTip="Press to update the list of Images that are loaded.">
                    <fa5:SvgAwesome Icon="Solid_RedoAlt" 
Height="20"
Width="30"
Foreground="#FF6B6B6B"/>
                </Button>
            </StackPanel>

            <StackPanel Style="{StaticResource HorizontalStack}" Orientation="Vertical">
                <StackPanel Style="{StaticResource HorizontalStack}">
                    <Label Content="Choose Equilization Type:" Style="{StaticResource InputTxtBoxLabel}"/>
                    <ComboBox ItemsSource="{Binding Source={StaticResource EquilType}}"
SelectedItem="{Binding EqualizationType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Style="{StaticResource HorizontalStack}">
                    <Label Content="Enter window name to display result:" Style="{StaticResource InputTxtBoxLabel}"/>
                    <TextBox Style="{StaticResource TxtBoxInputStyle}">
                        <TextBox.Text>
                            <Binding Path="EqualizationWindowName" UpdateSourceTrigger="PropertyChanged" Mode="TwoWay">
                                <Binding.ValidationRules>
                                    <DataErrorValidationRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                </StackPanel>

                <StackPanel Style="{StaticResource HorizontalStack}" Orientation="Vertical"
                            Visibility="{Binding AddPropertiesVisibility, UpdateSourceTrigger=PropertyChanged}">

                    <custControls:Slider LabelText="Clip Limit:"
                        Margin="20" Value="{Binding ClipLimit, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                        SliderStyle="{StaticResource ClipLimit}"
                        Minimum="2" Maximum="100"
                        />

                    <custControls:Slider LabelText="Grid Tile Width:"
                        Margin="20" Value="{Binding GridTileWidth, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                        SliderStyle="{StaticResource TileWidth}"
                        Minimum="8" Maximum="100"
                        />

                    <custControls:Slider LabelText="Grid Tile Height:"
                        Margin="20" Value="{Binding GridTileHeight, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                        SliderStyle="{StaticResource TileWidth}"
                        Minimum="8" Maximum="100"
                        />
                </StackPanel>

                <Grid Height="30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button Content="Equilize" Grid.Column="1" Style="{StaticResource SimpleButton}"
                  Command="{Binding OnEqualizeButtonPressed}"/>
                </Grid>
            </StackPanel>

        </StackPanel>
    </Grid>
</Page>
