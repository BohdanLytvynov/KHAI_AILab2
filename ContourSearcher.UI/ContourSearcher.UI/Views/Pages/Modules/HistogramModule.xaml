<Page x:Class="ContourSearcher.UI.Views.Pages.Modules.HistogramModule"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ContourSearcher.UI.Views.Pages.Modules"
      xmlns:fa5="http://schemas.fontawesome.com/icons/"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      xmlns:custControls="clr-namespace:UserControls;assembly=UserControls"
      xmlns:vm="clr-namespace:ContourSearcher.UI.ViewModels.Pages.Modules"
      Title="HistogramModule"
      d:DataContext="{d:DesignInstance vm:HistogramModuleViewModel, IsDesignTimeCreatable=True}">
    <Page.Resources>
        <Style x:Key="SliderHistSizeStyle" TargetType="Slider" BasedOn="{StaticResource SliderBaseStyle}">
            <Style.Setters>
                <Setter Property="TickFrequency" Value="128"/>
                <Setter Property="Interval" Value="128"/>
            </Style.Setters>
        </Style>
    </Page.Resources>
    <Grid>
        <StackPanel Orientation="Vertical">
            <Rectangle Style="{StaticResource BorderRectStyle}"/>
            <TextBlock Text="{Binding ModuleName}" Style="{StaticResource DescLabel}"/>
            <Rectangle Style="{StaticResource BorderRectStyle}"/>
            <StackPanel Style="{StaticResource HorizontalStack}">
                <Label Content="Choose source image for processing:" Style="{StaticResource InputTxtBoxLabel}"/>
                <ComboBox ItemsSource="{Binding ActiveWindows, UpdateSourceTrigger=PropertyChanged}"
              SelectedItem="{Binding ImgNameForProcessing, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                <Button Margin="20,0,0,0" Command="{Binding OnRefreshActiveWindowsPressed}"
            ToolTip="Press to update the list of Images that are loaded.">
                    <fa5:SvgAwesome Icon="Solid_RedoAlt" 
            Height="20"
            Width="30"
            Foreground="#FF6B6B6B"/>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Style="{StaticResource HorizontalStack}">
                <Label Content="Enter Histogram Name:" Style="{StaticResource InputTxtBoxLabel}"/>
                <TextBox Style="{StaticResource TxtBoxInputStyle}" MinWidth="100">
                    <TextBox.Text>
                        <Binding Path="HistName" UpdateSourceTrigger="PropertyChanged" Mode="TwoWay">
                            <Binding.ValidationRules>
                                <DataErrorValidationRule/>
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
            </StackPanel>

            <StackPanel Style="{StaticResource HorizontalStack}">
                <Label Style="{StaticResource InputTxtBoxLabel}" Content="Select a Channel:"
        Margin="10,0,0,0"/>
                <CheckBox Content="Blue" Style="{StaticResource CheckBoxStyle}" Foreground="Blue"
              IsChecked="{Binding BlueChannel, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
              />
                <CheckBox Content="Green" Style="{StaticResource CheckBoxStyle}" Foreground="Green"
              IsChecked="{Binding GreenChannel, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                <CheckBox Content="Red" Style="{StaticResource CheckBoxStyle}" Foreground="Red"
              IsChecked="{Binding RedChannel, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                <CheckBox Content="Draw All In One Plot" Style="{StaticResource CheckBoxStyle}"
              IsChecked="{Binding DrawAllInOnePlot, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
            </StackPanel>

            <custControls:Slider LabelText="Enter width of the Histogram:"
                Margin="20" 
                Value="{Binding HistWidth, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                SliderStyle="{StaticResource SliderHistSizeStyle}"
                Minimum="256" Maximum="512"
                     />

            <custControls:Slider LabelText="Enter height of the Histogram:"
                Margin="20" Value="{Binding HistHeight, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                SliderStyle="{StaticResource SliderHistSizeStyle}"
                Minimum="256" Maximum="512"
                />

            <Grid Height="30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button Content="Calculate" Grid.Column="1" Style="{StaticResource SimpleButton}"
            Command="{Binding OnCalculateHistogramPressed}"/>
            </Grid>
        </StackPanel>
    </Grid>
</Page>
