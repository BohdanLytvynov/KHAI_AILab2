<Page x:Class="ContourSearcher.UI.Views.Pages.Modules.FilteringModule"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ContourSearcher.UI.Views.Pages.Modules"
      xmlns:vm="clr-namespace:ContourSearcher.UI.ViewModels.Pages.Modules"
      xmlns:fa5="http://schemas.fontawesome.com/icons/"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="FilteringModule"
      d:DataContext="{d:DesignInstance vm:FilteringModuleViewModel, IsDesignTimeCreatable=True}"
      >
    <Grid>
        <StackPanel Orientation="Vertical">
            <Rectangle Style="{StaticResource BorderRectStyle}"/>
            <TextBlock Text="{Binding ModuleName}" Style="{StaticResource DescLabel}"/>
            <Rectangle Style="{StaticResource BorderRectStyle}"/>

            <StackPanel Style="{StaticResource HorizontalStack}">
                <Label Content="Choose source image for processing:" Style="{StaticResource InputTxtBoxLabel}"/>
                <ComboBox ItemsSource="{Binding ActiveWindows, UpdateSourceTrigger=PropertyChanged}"
  SelectedItem="{Binding ImgNameForProcessing, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                <Button Margin="20,0,0,0" Command="{Binding OnRefreshActiveWindowsPressed}"
ToolTip="Press to update the list of Images that are loaded.">
                    <fa5:SvgAwesome Icon="Solid_RedoAlt" 
Height="20"
Width="30"
Foreground="#FF6B6B6B"/>
                </Button>
            </StackPanel>

            <StackPanel Style="{StaticResource HorizontalStack}">
                <Label Content="Enter window name to display result:" Style="{StaticResource InputTxtBoxLabel}"/>
                <TextBox Style="{StaticResource TxtBoxInputStyle}">
                    <TextBox.Text>
                        <Binding Path="FilteringWindowName" UpdateSourceTrigger="PropertyChanged" Mode="TwoWay">
                            <Binding.ValidationRules>
                                <DataErrorValidationRule/>
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="5">
                <ComboBox MinWidth="150" Margin="0,0,5,0" ItemsSource="{Binding Source={StaticResource FilterType}}"/>
                <Button Content="Add Filter"
                        Command="{Binding OnAddFilterButtonPressed}"/>
                <Button Content="Apply All" Margin="5,0"/>
                <CheckBox Content="Show Filtering Progress:" Style="{StaticResource CheckBoxStyle}"/>
            </StackPanel>
            <ScrollViewer VerticalScrollBarVisibility="Visible">
                <ListView Height="800" ItemsSource="{Binding Filters, 
                    UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</Page>
