                        <StackPanel Orientation="Horizontal" Margin="10,10,0,0">
                            <Button Content="Apply Filter" Style="{StaticResource SimpleButton}"
                                    Margin="10,0"
                                    Command="{Binding OnApplyButtonPressed}"
                                    />
                            <Button Content="Remove Filter" Style="{StaticResource SimpleButton}"
                                    Command="{Binding OnDeleteButtonPressed}"
                                    />
                        </StackPanel>

                    </StackPanel>

                </StackPanel>
            </StackPanel>
        </Border>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsValid, UpdateSourceTrigger=PropertyChanged}" Value="False">
                <DataTrigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation To="OrangeRed" From="Black"
                                    Storyboard.TargetName="brdBrush"
                                    Storyboard.TargetProperty="Color"
                                    Duration="{StaticResource AnimDuration}"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation
                        To="Black" From="OrangeRed"
                        Storyboard.TargetName="brdBrush"
                        Storyboard.TargetProperty="Color"
                        Duration="{StaticResource AnimDuration}"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.ExitActions>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

