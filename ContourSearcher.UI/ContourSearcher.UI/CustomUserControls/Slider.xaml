<UserControl x:Class="ContourSearcher.UI.CustomUserControls.Slider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ContourSearcher.UI.CustomUserControls"
             xmlns:vm="clr-namespace:ContourSearcher.UI.CustomUserControls"
             xmlns:DtoStr="clr-namespace:ContourSearcher.UI.CustomUserControls.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="70" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:Slider, IsDesignTimeCreatable=True}"
             x:Name="Control">
    <UserControl.Resources>
        <DtoStr:DoubleToStringIntConverter x:Key="DoubleToStringIntegerConverter"/>
        <DtoStr:DoubleToStringFloatConverter x:Key="DoubleToStringFloatConverter"/>
        <Style x:Key="Border" TargetType="Border">
            <Style.Setters>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="Black"/>
                <Setter Property="CornerRadius" Value="1"/>
                <Setter Property="Padding" Value="8"/>
            </Style.Setters>
        </Style>

        <Style x:Key="SliderInternal" TargetType="Slider">
            <Style.Setters>
                <Setter Property="Margin" Value="0,5,0,0"/>
                <Setter Property="TickPlacement" Value="BottomRight"/>
                <Setter Property="TickFrequency" Value="0.1"/>
                <Setter Property="Foreground" Value="Black"/>
            </Style.Setters>
        </Style>
    </UserControl.Resources>
    <Grid Background="White" DataContext="{Binding ElementName=Control}">
        <Border Style="{StaticResource Border}">
            <StackPanel x:Name="StackVertical" Orientation="Vertical">
                <StackPanel x:Name="StackHorizontal" Orientation="Horizontal">
                    <Label x:Name="Label" Content="{Binding LabelText, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox x:Name="IntegerPart" MinWidth="10" TextChanged="IntegerPart_TextChanged"
                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay,
                        Converter={StaticResource DoubleToStringIntegerConverter}, ConverterParameter=','}"/>
                    <Label Content="{Binding Deliminator, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Bottom"/>
                    <TextBox x:Name="FloatPart" MinWidth="10" TextChanged="FloatPart_TextChanged"
                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay,
                        Converter={StaticResource DoubleToStringFloatConverter}, ConverterParameter=','}"/>
                </StackPanel>
                <Slider x:Name="SliderValue" Style="{StaticResource SliderInternal}"
                Width="{Binding ElementName=Control,
                UpdateSourceTrigger=PropertyChanged,
                Path=Width}" Value="{Binding Value,UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
