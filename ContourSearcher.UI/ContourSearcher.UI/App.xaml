<Application x:Class="ContourSearcher.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ContourSearcher.UI"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ContourSearcher.UI;component/Resources/CommonStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/UserControls;component/ControlStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/ContourSearcher.UI;component/Resources/DataTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
