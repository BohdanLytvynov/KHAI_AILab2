<UserControl x:Class="UserControls.Cell"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UserControls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance local:Cell, IsDesignTimeCreatable=True}"
             x:Name="Root"
             >
    <Grid DataContext="{Binding ElementName=Root}">
        <TextBox Style="{StaticResource TxtBoxInputStyle}">
            <TextBox.Text>
                <Binding Path="ValueString" UpdateSourceTrigger="PropertyChanged" Mode="TwoWay">
                    <Binding.ValidationRules>
                        <DataErrorValidationRule/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox.Text>
        </TextBox>
    </Grid>
</UserControl>
